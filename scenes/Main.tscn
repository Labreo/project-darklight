; ============================================================
; Main scene — Project Darklight
; Contains:
;   BottomBar   — always-visible navigation (CanvasLayer)
;   Overlays    — five mode panels (CanvasLayer above bottom bar)
; ============================================================

[node name="Main" type="Node" unique_id=1096816219]
script = ExtResource("1_mainscript")

; ─────────────────────────────────────────────────────────────
; GAME VIEW — fullscreen Control, location scenes load here.
; Control children (Apartment, etc.) auto-fill this rect.
; CanvasLayer overlays (BottomBar, panels) render above it.
; ─────────────────────────────────────────────────────────────
[node name="GameView" type="Control" parent="." unique_id=100000001]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

; ─────────────────────────────────────────────────────────────
; BOTTOM BAR  (layer 1)
; ─────────────────────────────────────────────────────────────
[node name="BottomBar" type="CanvasLayer" parent="." unique_id=91106234]
layer = 1

[node name="HBoxContainer" type="HBoxContainer" parent="BottomBar" unique_id=430566654]
anchors_preset = 12
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -52.0
grow_horizontal = 2
grow_vertical = 0

[node name="BtnInvestigate" type="Button" parent="BottomBar/HBoxContainer" unique_id=1921606050]
layout_mode = 2
size_flags_horizontal = 3
text = "Investigate"
toggle_mode = true

[node name="BtnTalk" type="Button" parent="BottomBar/HBoxContainer" unique_id=2005974386]
